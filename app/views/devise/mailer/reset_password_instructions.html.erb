<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #f5f5f5;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f5f5f5; padding: 40px 20px;">
    <tr>
      <td align="center">
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width: 480px; background-color: #ffffff; border-radius: 8px;">
          <tr>
            <td style="padding: 40px 40px 30px; text-align: center;">
              <h1 style="margin: 0 0 8px; font-size: 28px; font-weight: 700; color: #6b46c1;">King of 20</h1>
            </td>
          </tr>
          <tr>
            <td style="padding: 0 40px; text-align: center;">
              <h2 style="margin: 0 0 30px; font-size: 22px; font-weight: 400; color: #333333;">
                Hi <%= @resource.username %>, let's reset your password.
              </h2>
            </td>
          </tr>
          <tr>
            <td style="padding: 0 40px 30px; text-align: center;">
              <a href="<%= @reset_url %>" style="display: inline-block; padding: 14px 32px; background-color: #6b46c1; color: #ffffff; text-decoration: none; font-size: 16px; font-weight: 600; border-radius: 6px;">
                Reset Your Password
              </a>
            </td>
          </tr>
          <tr>
            <td style="padding: 0 40px 30px; text-align: center; color: #666666; font-size: 14px; line-height: 1.6;">
              <p style="margin: 0 0 10px;">If the above button does not work for you, copy and paste the following into your browser's address bar:</p>
              <p style="margin: 0; word-break: break-all;">
                <a href="<%= @reset_url %>" style="color: #6b46c1;"><%= @reset_url %></a>
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding: 0 40px 40px; text-align: center; color: #999999; font-size: 13px;">
              <p style="margin: 0;">If you didn't ask to reset your password, you can disregard this email.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
